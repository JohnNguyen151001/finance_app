<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_card_soft"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <TextView
        android:id="@+id/tr_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_input_field"
        android:gravity="center"
        android:textSize="16sp"
        tools:text="🍔" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tr_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            tools:text="Ăn trưa công ty" />

        <TextView
            android:id="@+id/tr_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="sans-serif"
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            tools:text="Ăn uống · Hôm qua" />
    </LinearLayout>

    <TextView
        android:id="@+id/tr_amount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/expense_red"
        android:textSize="14sp"
        tools:text="-120,000 đ" />
</LinearLayout>
